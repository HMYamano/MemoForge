# Copy this file to `.env` if you want to override Docker defaults.
# Example:
#   cp .env.example .env
#   # or on PowerShell:
#   Copy-Item .env.example .env

REASONING_MODEL=qwen3:30b
VISION_MODEL=gemma3:27b
EMBEDDING_MODEL=embeddinggemma
PDF_VISION_MAX_PAGES=4
MAX_RELATED_NOTES=5

# Ollama request timeout in seconds (default: 600).
# Increase for very large models or slow hardware.
# OLLAMA_TIMEOUT=600

# Maximum upload file size in bytes (default: 104857600 = 100 MB).
# MAX_UPLOAD_BYTES=104857600

# incoming/ directory watcher (default: disabled).
# Set to "true" to auto-create a run whenever a file is dropped in incoming/.
# WATCHER_ENABLED=false
# WATCHER_LANG=ja

# Local execution (without Docker): override the default /app/* paths.
# APP_DATA_DIR=./data
# NOTES_DIR=./notes
# INCOMING_DIR=./incoming

# Lighter example profile for smaller GPUs / RAM:
# REASONING_MODEL=qwen3:14b
# VISION_MODEL=gemma3:12b
